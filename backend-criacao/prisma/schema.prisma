// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        String   @id @default(uuid())
  nome      String
  email     String   @unique
  senha     String   // Aqui guardaremos a senha criptografada depois
  criadoEm  DateTime @default(now())

  @@map("usuarios") // Isso diz pro MySQL criar a tabela com o nome em minúsculo e no plural
}

model Cliente {
  id        String   @id @default(uuid())
  nome      String
  telefone  String
  email     String?
  senha     String?  // <-- NOVO: A senha do cliente para ele acessar o site!
  criadoEm  DateTime @default(now())
  
  pedidos   Pedido[] 

  @@map("clientes")
}

model Pedido {
  id          String   @id @default(uuid())
  descricao   String   
  valor       Float    
  status      String   @default("ORÇAMENTO") 
  arquivoArte String?  // <-- NOVO: Onde vamos salvar o link do PDF do cliente
  detalhes    Json?    // <-- NOVO: Salva as escolhas exatas (Ex: Papel 300g, 1000 un)
  criadoEm    DateTime @default(now())

  clienteId   String
  cliente     Cliente  @relation(fields: [clienteId], references: [id])

  @@map("pedidos")
}

model Produto {
  id          String   @id @default(uuid())
  nome        String   
  descricao   String?  
  precoBase   Float    
  imagemUrl   String?  // Capa principal
  variacoes   Json?    // <-- NOVO: O "superpoder" flexível (Materiais, Quantidades, Acabamentos)
  criadoEm    DateTime @default(now())

  imagens     ImagemProduto[] // <-- NOVO: A galeria de fotos extras no rodapé

  @@map("produtos")
}

// <-- NOVA TABELA: Para o rodapé de fotos extras
model ImagemProduto {
  id        String  @id @default(uuid())
  url       String
  produtoId String
  
  // O onDelete: Cascade significa que se o seu sogro apagar o Produto, as fotos extras dele também são apagadas do banco!
  produto   Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@map("imagens_produto")
}